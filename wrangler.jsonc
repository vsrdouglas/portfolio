{
  // Cloudflare Workers static-assets config.
  // `npm run build` outputs to ./dist, which is served directly as a static site.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./dist",
    // Single page site: serve index.html for any unmatched path.
    "not_found_handling": "single-page-application"
  }
}
